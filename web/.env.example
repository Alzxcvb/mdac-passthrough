# Backend (Railway) URL the web app calls for auto-submit / session relay.
NEXT_PUBLIC_PASSTHROUGH_URL=https://mdac-passthrough-production.up.railway.app

# Passport-scan autofill (Step 1 "Scan passport" button). OpenRouter key used by
# /api/scan-passport to OCR a passport image into form fields. Leave unset to
# disable scanning (the route returns a clear "not configured" error).
OPENROUTER_API_KEY=

# Optional: referer header sent to OpenRouter (defaults to the prod URL).
PUBLIC_URL=https://mdac-passthrough.vercel.app
